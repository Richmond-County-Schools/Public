##### UI++ is a third-party application that integrates with Endpoint Configuration Manager.
  -The UI++ final data needs to be in \\ANXSCCM\OSD\UI++
  -In MECM a package is built that launches UI++.exe and reads the UI++.xml file.
  -UI++ runs once a task sequence is selected when imaging.
  -When running it collects data from the user and when complete it passes that information back to MECM to use through the imaging process.
<?xml version="1.0" encoding="utf-8"?>

##### App information.  
  -Title is what is in the side bar of the first dialog box.
  -Icon is the little graphic on first dialog box.
  -Color is the color of the side bar in first dialog box.		
<UIpp Title="RCS Technology" Icon="rcs.ico" Color="#4CBB17" DialogIcons="Yes">


##### Beginning of the task list.
  <Actions>
##### This is for the collection of machine data. Other data types are available if needed.    
    <Action Type="DefaultValues" ValueTypes="Asset" ShowProgress="True">
      <Text Type="Asset" Value="Retrieving Asset information" />
    </Action>  
    
#####This section sets certain variables to a default value to help bypass user prompts and simplfy the logic when possible.
    <Action Type="TSVar" Name="PCType">"Unknown"</Action>

  #####Sets the PCType variable based on the default XHWChassisType variable. If the %PCType% variable is not set, then it will still be set to "Unknown" from earlier and the next action will prompt for user input.
    <!-- Automatically detect Desktop types -->
    <Action Type="TSVar" Name="PCType" Condition='
    "%XHWChassisType%" = "Desktop" OR 
    "%XHWChassisType%" = "Server" OR 
    "%XHWChassisType%" = "Low Profile Desktop" OR 
    "%XHWChassisType%" = "Pizza Box" OR 
    "%XHWChassisType%" = "Mini Tower" OR 
    "%XHWChassisType%" = "Tower" OR 
    "%XHWChassisType%" = "All in One"'>"Desktop"</Action>

    <!-- Automatically detect Laptop types -->
    <Action Type="TSVar" Name="PCType" Condition='
    "%XHWChassisType%" = "Laptop" OR 
    "%XHWChassisType%" = "Tablet" OR 
    "%XHWChassisType%" = "Portable" OR 
    "%XHWChassisType%" = "Notebook" OR 
    "%XHWChassisType%" = "Handheld" OR 
    "%XHWChassisType%" = "Sub Notebook" OR 
    "%XHWChassisType%" = "Convertible" OR 
    "%XHWChassisType%" = "Detachable" OR 
    "%XHWChassisType%" = "Lunch Box"'>"Laptop"</Action>

    #####If %PCType% is still set to Unknown from the default variable section earlier, then the user will be prompted to input the information.
    <Action Type="Input" Name="PCType" Title="Type of Device" ShowBack="True" Condition='"%PCType%" = "Unknown"'>
      <ChoiceInput Variable="PCType" Question="System Type" Required="True">
        <Choice Option="Desktop" Value="Desktop" />
        <Choice Option="Laptop" Value="Laptop" />
      </ChoiceInput>
    </Action>

    #### This sets the prefix for computer types    
    <Action Type="TSVar" Name="SystemSuffix" Condition='"%PCType%" = "Desktop"'>DT</Action>
    <Action Type="TSVar" Name="SystemSuffix" Condition='"%PCType%" = "Laptop"'>LT</Action>

#####Question to determine the location of the device and a checkbox to set the variable %ComputerLab%
    <Action Type="Input" Name="ClientSetupInput" Title="Client Setup" >
      <ChoiceInput Variable="LocationPrefix" DropDownSize="18" ShowBack="True" Question="Location" AutoComplete="True" Required="True">
        <Choice Option="Annex" Value="ANX" />            
        <Choice Option="Ashley Chapel" Value="ACE" />
        <Choice Option="Bus Garage" Value="BUS" />
        <Choice Option="Central Office" Value="RCS" />
        <Choice Option="Cordova Middle" Value="CMS" />
        <Choice Option="Early College" Value="REC" />
        <Choice Option="East Rockingham" Value="ERS" />   
        <Choice Option="Ellerbe Middle" Value="EMS" />
        <Choice Option="Fairview Heights" Value="FHS" />
        <Choice Option="Hamlet Middle" Value="HMS" />
        <Choice Option="L.J. Bell" Value="LJB" />
        <Choice Option="Maintenance" Value="MNT" />
        <Choice Option="Mineral Springs" Value="MSE" />
        <Choice Option="Monroe Avenue" Value="MAS" />
        <Choice Option="Richmond Senior High" Value="RSH" />  
        <Choice Option="Rockingham Middle" Value="RMS" />
        <Choice Option="Washington Street" Value="WSS" />        
        <Choice Option="West Rockingham" Value="WRS" />
      </ChoiceInput>
      <InputCheckbox Variable="ComputerLab" Question="Is this in a computer lab?" CheckedValue="True" UncheckedValue="False"/>
      <InputCheckbox Variable="Software" Question="Do you need specific software?" CheckedValue="True" UncheckedValue="False"/>
      <InputCheckbox Variable="CN" Question="Is this device for Child Nutrition?" CheckedValue="True" UncheckedValue="False"/>
    </Action>

    <Action Type="Input" Name="SoftwareChoice" Title="Software Choices" ShowBack="True" Condition='"%Software%" = "True"'>
      <InputCheckbox Variable="FI" Question="LINQ       " CheckedValue="True" UncheckedValue="False"/>
      <InputCheckbox Variable="CN" Question="Meals Plus " CheckedValue="True" UncheckedValue="False"/>
      <InputCheckbox Variable="BC" Question="Bus Cameras" CheckedValue="True" UncheckedValue="False"/>
    </Action>

    <Action Type="TSVar" Name="OSDgroupTag">"SD"</Action>
    <Action Type="TSVar" Name="OSDgroupTag" Condition='"%XHWModel%" = "HP 255 G7 Notebook PC"'>"UD"</Action>
    <Action Type="TSVar" Name="OSDgroupTag" Condition='"%XHWModel%" = "HP 255 G8 Notebook PC"'>"UD"</Action>

##### This Section is for Computer Lab Choices.  It will set the OSDgroupTag variable based on the location and computer lab choices made by the user.
    <ActionGroup Name="Computer Lab Choices" Condition='"%ComputerLab%" = "True"'>

##### This section is for schools that only have one lab, so not additional question is necessary to determine the correct OU
      <Action Type="TSVar" Name="LabNumber" Condition='"%ComputerLab%" = "True" AND "%LocationPrefix%" != "RSH" AND "%LocationPrefix%" != "RMS"'>"L1"</Action>

##### This section is for schools that have multiple labs and will need more information to determine the correct OU   
      <Action Type="Input" Name="Computer Lab Selection" Title="Select Computer Lab" ShowBack="True" Condition='"%LocationPrefix%" = "RMS"'>
        <ChoiceInput Variable="LabNumber" Question="What Room is the Computer Lab in?" Required="True">
          <Choice Option="110" Value="L1" />
          <Choice Option="210" Value="L2" />
          <Choice Option="310" Value="L3" />
          <Choice Option="531" Value="L4" />
        </ChoiceInput>
      </Action>         
      <Action Type="Input" Name="Computer Lab Selection" Title="Select Computer Lab" ShowBack="True" Condition='"%LocationPrefix%" = "RSH"'>
        <ChoiceInput Variable="LabNumber" Question="What Room is the Computer Lab in?" Required="True">
          <Choice Option="A-202" Value="L1" />
          <Choice Option="A-203" Value="L2" />
          <Choice Option="A-207" Value="L3" />
          <Choice Option="A-208" Value="L4" />
          <Choice Option="A-210" Value="L5" />
          <Choice Option="A-211" Value="L6" />
          <Choice Option="E-201" Value="L7" />
          <Choice Option="E-202" Value="L8" />
          <Choice Option="E-106" Value="L9" />
          <Choice Option="E-105 (E-Sports)" Value="L0" />
        </ChoiceInput>
      </Action>

      <Action Type="TSVar" Name="OSDgroupTag">"%OSDgroupTag%--%LabNumber%"</Action>

##### This is the last prompt before imaging starts.  It displays a summary of information based on choices made and information entered.
    </ActionGroup>

    <Action Type="TSVar" Name="OSDgroupTag" Condition='"%FI%" = "True"'>"%OSDgroupTag%-FI"</Action>
    <Action Type="TSVar" Name="OSDgroupTag" Condition='"%CN%" = "True"'>"%OSDgroupTag%--CN"</Action>
    <Action Type="TSVar" Name="OSDgroupTag" Condition='"%BC%" = "True"'>"%OSDgroupTag%--BC"</Action>
    
    <Action Type="TSVar" Name="SoftwareSelections" Condition='"%Software%" = "True"'>"Base Software"</Action>
    <Action Type="TSVar" Name="SoftwareSelections" Condition='"%FI%" = "True"'>"%SoftwareSelections%, LINQ"</Action>
    <Action Type="TSVar" Name="SoftwareSelections" Condition='"%CN%" = "True"'>"%SoftwareSelections%, Meals Plus"</Action>
    <Action Type="TSVar" Name="SoftwareSelections" Condition='"%BC%" = "True"'>"%SoftwareSelections%, Bus Cameras"</Action>

    ##### This section is for entering the Asset Tag #.	
	  <Action Type="Input" Name="ServiceTag" ShowBack="True" Title="Please Enter Fixed Asset Tag" Condition='"%CN%" = "False"'>
      <TextInput Prompt="Fixed Asset" Hint="Fixed Asset Should be 5 Digits Long" Question="Please Enter Fixed Asset" RegEx=".{5}" Variable="FixedAsset" />
    </Action>
    ##### This section is for entering the Asset Tag # for Child Nutrition devices.	
    <Action Type="Input" Name="ServiceTag" ShowBack="True" Title="Please Enter Fixed Asset Tag" Condition='"%CN%" = "True"'>
      <TextInput Prompt="Enter 4-digit Asset Number" Hint="4 digits (e.g., 1234)" Question="Enter 4-digit Asset Number" RegEx="^\d{4}$" Variable="AssetDigitsOnly" />
    </Action>
    <Action Type="TSVar" Name="FixedAsset" Condition='"%CN%" = "True"'>C%AssetDigitsOnly%</Action>

    
    ####This section names the computer for Intune; if the computer is AD, the OSDComputerName variable will be reset later on in the task sequence
    <Action Type="TSVar" Name="OSDComputerName" DontEval="True">%LocationPrefix%%SystemSuffix%-%FixedAsset%</Action>

##### This is the last prompt before imaging starts for Intune devices.  It displays a summary of information based on choices made and information entered.	 
    <!-- Base Info Screen (No Lab, No Special Software) -->
    <Action Type="Info" Title="Summary" Name="FinalSummary" ShowBack="True" Condition='"%ComputerLab%" = "False" AND "%Software%" = "False"'>
    <![CDATA[
    This computer will be named %OSDComputerName%.

    • Location: %LocationPrefix%  
    • Group Tag: %OSDgroupTag%
    • Software: %SoftwareSelections%

    ]]>
    </Action>

    <!-- Lab Computer Only -->
    <Action Type="Info" Title="Summary" Name="LabOnly" ShowBack="True" Condition='"%ComputerLab%" = "True"'>
    <![CDATA[
    This computer will be named %OSDComputerName%.

    • Location: %LocationPrefix%  
    • Group Tag: %OSDgroupTag%
    • Lab: Yes
    • Software: %SoftwareSelections%

    ]]>
    </Action>
    <Action Type="RegWrite" Hive="HKLM" Key="SOFTWARE\RCS\DeviceInfo" Value="DisplayName" ValueType="REG_SZ">%OSDComputerName%</Action>
    <Action Type="RegWrite" Hive="HKLM" Key="SOFTWARE\RCS\DeviceInfo" Value="GroupTag" ValueType="REG_SZ">%OSDgroupTag%</Action>
  </Actions>
</UIpp>